{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Intrusion Detection Schema",
  "description": "Schema for intrusion detection metadata from edge camera systems",
  "type": "object",
  "required": ["camera_id", "timestamp", "location", "intrusion_type", "confidence"],
  "properties": {
    "camera_id": {
      "type": "string",
      "description": "Unique identifier for the camera that detected the intrusion",
      "example": "CAM-01"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the intrusion was detected"
    },
    "location": {
      "type": "object",
      "description": "Geographic location where the intrusion was detected",
      "required": ["lat", "lng"],
      "properties": {
        "lat": {
          "type": "number",
          "description": "Latitude coordinate"
        },
        "lng": {
          "type": "number",
          "description": "Longitude coordinate"
        }
      }
    },
    "intrusion_type": {
      "type": "string",
      "enum": ["person", "drone", "vehicle"],
      "description": "Type of intrusion detected"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Detection confidence score (0-100)"
    }
  }
}
